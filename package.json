{
  "name": "my-project",
  "version": "1.0.0",
  "description": "A sample project for GitHub Actions workflows",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "vite build",
    "test": "jest",
    "lint": "eslint .",
    "optimize-icons": "npx imagemin icons/* --out-dir=dist/icons"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/your-repo.git"
  },
  "keywords": ["github-actions", "ci", "automation", "static-site"],
  "author": "Your Name",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/your-username/your-repo/issues"
  },
  "homepage": "https://your-username.github.io/your-repo",
  "dependencies": {
    "vite": "^4.0.0"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "imagemin": "^7.0.0",
    "imagemin-cli": "^6.0.0",
    "imagemin-mozjpeg": "^9.0.0",
    "imagemin-pngquant": "^9.0.0"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "node": true,
      "es2021": true
    },
    "extends": ["eslint:recommended"],
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": "warn",
      "semi": ["error", "always"],
      "quotes": ["error", "double"]
    }
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "collectCoverage": true
  }
}
